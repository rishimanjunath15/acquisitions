{
  "family": "acquisitions-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::655024857157:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "acquisitions-container",
      "image": "rishimanjunath/acquisitions:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "3000" },
        { "name": "NODE_ENV", "value": "production" },
        {
          "name": "DATABASE_URL",
          "value": "postgresql://neondb_owner:npg_6lJ5KpGdLCqI@ep-misty-bird-adh56mhf-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require"
        },
        { "name": "ARCJET_KEY", "value": "ajkey_01k82fhwpce01tkd6x9wtpq45y" },
        { "name": "ARCJET_ENV", "value": "production" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/acquisitions",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
